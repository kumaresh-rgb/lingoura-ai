# ─────────────────────────────────────────────────────────────────────────────
# Lingoura AI — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public (exposed to browser) ──────────────────────────────────────────────
# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=https://localhost:44301/api/v1

# Frontend app URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth client ID (public — safe for browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# App display name
NEXT_PUBLIC_APP_NAME=Lingoura AI

# App version (injected by CI)
NEXT_PUBLIC_APP_VERSION=dev

# ── Server-only (NEVER prefix with NEXT_PUBLIC_) ─────────────────────────────
# Google OAuth client secret — server only, never expose to browser
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Dev only: allows server-side fetch to trust the ASP.NET Core self-signed dev cert.
# Remove in production.
NODE_TLS_REJECT_UNAUTHORIZED=0
