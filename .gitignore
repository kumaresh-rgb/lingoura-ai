# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ============================================================
# Node / Next.js
# ============================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/coverage
/.next/
/out/
/build

*.tsbuildinfo
next-env.d.ts

# ============================================================
# .NET / C# build artifacts
# ============================================================
# Compiler output — never commit
[Bb]in/
[Oo]bj/

# NuGet packages (restored on build — never commit)
*.nupkg
*.snupkg
**/packages/
!**/packages/build/
nuget.config.lock
project.lock.json
project.fragment.lock.json
artifacts/

# dotnet publish output
publish/
PublishProfiles/
**/Properties/PublishProfiles/

# ============================================================
# EF Core — what to ignore vs. what to commit
# ============================================================
# Migration .cs files, Designer.cs files, and ModelSnapshot.cs
# are ALL intentionally committed. They are the authoritative
# migration history that allows the team to replay schema changes
# and prevents "can't scaffold next migration" errors.
#
#   backend/src/Lingoura.Infrastructure/Persistence/Migrations/
#     ├── 20xxxxxx_*.cs            ← COMMIT (migration logic)
#     ├── 20xxxxxx_*.Designer.cs   ← COMMIT (before-state snapshot for tooling)
#     └── *ModelSnapshot.cs        ← COMMIT (current model snapshot for tooling)
#
# DO NOT add Migrations/ or *ModelSnapshot.cs here.

# EF design-time scaffolding temp cache (safe to ignore)
*.lscache

# ============================================================
# IDE & editor artifacts
# ============================================================
# Visual Studio
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Rider / JetBrains
.idea/
*.DotSettings.user
*.iml

# VS Code C# extension launch configs (machine-specific)
.vscode/launch.json
.vscode/tasks.json

# Misc IDE artifacts
*.pidb
*.booproj
*.svd
*.userprefs

# ============================================================
# Test artifacts
# ============================================================
TestResults/
[Tt]est[Rr]esult*/
*.trx
*.coverage
*.coveragexml
coverage-report/
BenchmarkDotNet.Artifacts/

# ============================================================
# Runtime artifacts
# ============================================================
# Serilog rolling log files
logs/
*.log

# ASP.NET Core Data Protection keys (machine-specific)
**/DataProtection-Keys/

# Profiling output
*.etl
*.etlx
*.nettrace
*.speedscope.json

# ============================================================
# Secrets — never commit
# ============================================================
# appsettings.Development.json IS committed (no real secrets inside).
# Real secrets live in .NET User Secrets or environment variables.
appsettings.*.local.json
secrets.json
*.pfx
*.p12
*.pem
*.key
*.crt
*.cer

# ============================================================
# Docker
# ============================================================
.dockerignore

# ============================================================
# Claude Code / AI tooling
# ============================================================
.claude/

# ============================================================
# OS artifacts
# ============================================================
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ============================================================
# Misc
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (use .NET User Secrets or env vars for backend)
.env*
!.env.example

# Vercel
.vercel

# Temp files
*.tmp
*.temp
~$*
